# ============================================================
# SIGEO v2 Backend - Variáveis de ambiente (AWS EC2 / Lambda)
# Copie para .env e preencha os valores.
# ============================================================

# --- Opção 1: Secrets Manager (recomendado em produção) ---
# ARN do secret no AWS Secrets Manager (credenciais Aurora em tempo real; EC2 precisa de IAM Role)
# SECRET_ARN=arn:aws:secretsmanager:sa-east-1:ACCOUNT:secret:rds!cluster-xxx
# SECRET_DATABASE=sigeo_db
# AWS_REGION=sa-east-1

# --- Opção 2: String de conexão direta ---
# DATABASE_URL=mysql://admin:senha@sigeo-cluster.xxx.rds.amazonaws.com:3306/sigeo_db
# ou postgresql://...

# JWT para tokens de autenticação (Web + Mobile)
JWT_SECRET=gere_um_secret_longo_e_aleatorio_aqui

# CORS (origem do frontend)
FRONTEND_URL=https://sigeo.advances.com.br

# Porta do servidor
PORT=3000

# Opcional: Firebase Admin (push notifications)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
