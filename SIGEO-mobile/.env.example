# URL da API SIGEO (backend)
#
# No CELULAR, "localhost" é o próprio aparelho — use o IP do seu PC.
# 1. No PC: ipconfig (Windows) ou ifconfig (Mac/Linux)
# 2. Pegue o IPv4 da rede Wi‑Fi (ex: 192.168.1.11)
# 3. Coloque abaixo com a porta do seu backend (ex: 3000, 8000)
#
# Desenvolvimento local (app no celular → backend no PC):
# EXPO_PUBLIC_API_URL=http://192.168.1.11:3000
#
# Produção (deixe em branco para usar o padrão):
# EXPO_PUBLIC_API_URL=https://api.sigeo.advances.com.br

EXPO_PUBLIC_API_URL=
